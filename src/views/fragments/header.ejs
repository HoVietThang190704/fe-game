<header class="header">
  <div class="header__promo-bar">
    <span>🎁 Mở bán Xiaomi 17 Series - Ưu đãi đến 2 triệu đồng</span>
  </div>

  <div class="header__main">
    <div class="header__container">
      <a href="/" class="header__logo" aria-label="Trang chủ">
        <div class="header__logo-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="18" cy="18" r="18" fill="#000"/>
            <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#ffd400" font-size="11" font-weight="bold" font-family="Arial">TGDĐ</text>
          </svg>
        </div>
        <div class="header__logo-text">
          <span class="logo-main">thegioididong</span>
          <span class="logo-dot">.com</span>
        </div>
      </a>

      <form action="/tim-kiem" class="header__search" onsubmit="return handleSearch(event);">
        <div class="search__wrapper">
          <svg class="search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            id="skw"
            type="text"
            class="search__input"
            name="key"
            placeholder="Bạn cần tìm sản phẩm gì?"
            autocomplete="off"
            maxlength="100"
          >
          <button type="submit" class="search__btn" aria-label="Tìm kiếm">
            Tìm kiếm
          </button>
        </div>
        <div id="search-result" class="search__dropdown" style="display:none;"></div>
      </form>

      <div class="header__actions">
        <a href="/dang-nhap" class="header__action-btn" id="btn-login">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span>Đăng nhập</span>
        </a>

        <a href="/cart" class="header__action-btn header__cart" id="cart-box">
          <div class="cart__icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <span class="cart__badge" id="cart-count"></span>
          </div>
          <span>Giỏ hàng</span>
        </a>

        <a href="javascript:;" class="header__action-btn header__location" onclick="OpenLocation()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span id="current-location">Hồ Chí Minh</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chevron">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <nav class="header__nav">
    <div class="header__container">
      <ul class="nav__list">
        <li class="nav__item">
          <a href="/dien-thoai" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2"/></svg>
            Điện thoại
          </a>
        </li>
        <li class="nav__item">
          <a href="/laptop" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M0 21h24"/></svg>
            Laptop
          </a>
        </li>
        <li class="nav__item">
          <a href="/tablet" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2"/></svg>
            Tablet
          </a>
        </li>
        <li class="nav__item">
          <a href="/phu-kien" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Phụ kiện
          </a>
        </li>
        <li class="nav__item">
          <a href="/smartwatch" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="7"/><polyline points="12 9 12 12 13.5 13.5"/><path d="M16.51 17.35l-.35 3.83a2 2 0 0 1-2 1.82H9.83a2 2 0 0 1-2-1.82l-.35-3.83m.01-10.7l.35-3.83A2 2 0 0 1 9.83 1h4.35a2 2 0 0 1 2 1.82l.35 3.83"/></svg>
            Smartwatch
          </a>
        </li>
        <li class="nav__item">
          <a href="/dong-ho" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Đồng hồ
          </a>
        </li>
        <li class="nav__item">
          <a href="/may-cu" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            Máy cũ
          </a>
        </li>
        <li class="nav__item">
          <a href="/man-hinh" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Màn hình
          </a>
        </li>
        <li class="nav__item">
          <a href="/sim-the-cao" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            Sim & Thẻ cào
          </a>
        </li>
        <li class="nav__item">
          <a href="/dich-vu" class="nav__link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Dịch vụ
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="remind_location hide">
    <div class="remind_question">
      Bạn đang ở tại <b>Hồ Chí Minh</b>?
      <span class="remind_change">Sửa</span>
    </div>
    <p class="remind_content">Giá và khuyến mãi đang lấy theo khu vực này.</p>
    <div class="remind_btn-close"></div>
  </div>
</header>

<script>
  function handleSearch(e) {
    const key = document.getElementById('skw').value.trim();
    if (!key) { e.preventDefault(); return false; }
    return true;
  }

  function OpenLocation() {
    alert('Chức năng chọn địa điểm');
  }

  document.addEventListener('DOMContentLoaded', function () {
    var remind = document.querySelector('.remind_location');
    if (remind) {
      remind.addEventListener('click', function (e) { e.stopPropagation(); });
    }
    var change = document.querySelector('.remind_change');
    if (change) {
      change.addEventListener('click', function (e) {
        e.stopPropagation();
        OpenLocation();
      });
    }
    var btn = document.querySelector('.remind_btn-close');
    if (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        document.querySelector('.remind_location').classList.add('hide');
      });
    }
  });
</script>
